# ============================================================
# HACK-CTF Platform — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.

# -----------------------------------------------------------
# Supabase
# Get these from: https://app.supabase.com → Project → Settings → API
# -----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: used in server-side operations requiring elevated access
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------
# Rate limiting (optional — production)
# For multi-instance deployments, replace the in-memory rate limiter with
# Upstash Redis. Create a database at https://console.upstash.com and
# copy the REST credentials below.
# If these variables are absent the app falls back to an in-memory limiter
# (suitable for single-instance / development use only).
# -----------------------------------------------------------
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token
